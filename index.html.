            return;
        }
        container.innerHTML = localFiles.map(file => `
            <div class="local-file-item" onclick="openPlayer('${file.name}')">
                <div class="local-file-icon"><i class="fas fa-${file.type === 'video' ? 'film' : file.type === 'audio' ? 'music' : 'file'}"></i></div>
