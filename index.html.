<!DOCTYPE html>
<html lang="pt-pt">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>BRM Pro Max</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <style>
        :root { --bg: #000; --accent: #00f2ff; --card: #111; --gray: #888; }
        * { box-sizing: border-box; -webkit-tap-highlight-color: transparent; }
        body { background: var(--bg); color: white; font-family: sans-serif; margin: 0; padding-bottom: 80px; overflow-x: hidden; }

        /* HEADER - SÓ APARECE NA HOME */
        header { position: fixed; top: 0; width: 100%; z-index: 1000; display: none; align-items: center; padding: 10px 15px; background: linear-gradient(to bottom, rgba(0,0,0,0.9), transparent); backdrop-filter: blur(5px); }
        header.active { display: flex; }
        .logo-img { height: 42px; margin-right: 12px; filter: drop-shadow(0 0 5px var(--accent)); }
        .search-box { flex: 1; background: rgba(255,255,255,0.1); border-radius: 20px; padding: 7px 15px; display: flex; align-items: center; }
        .search-box input { background: none; border: none; color: white; width: 100%; outline: none; }

        /* PAGES */
        .page { display: none; animation: fadeIn 0.4s; min-height: 100vh; }
        .page.active { display: block; }

        /* HOME */
        .hero { width: 100%; height: 500px; background-size: cover; background-position: center; display: flex; align-items: flex-end; padding: 40px 20px; cursor: pointer; }
        .info-box { background: rgba(0,0,0,0.4); backdrop-filter: blur(10px); padding: 15px; border-radius: 4px; border-left: 3px solid var(--accent); }
        .cat-title { padding: 20px 15px 5px; color: var(--accent); font-weight: bold; font-size: 14px; }
        .scroll-row { display: flex; overflow-x: auto; gap: 10px; padding: 0 15px; }
        .scroll-row::-webkit-scrollbar { display: none; }
        .movie-card { min-width: 115px; height: 165px; background: var(--card); border-radius: 8px; border: 1px solid #222; flex-shrink: 0; position: relative; background-size: cover; background-position: center; cursor: pointer; transition: transform 0.2s; }
        .movie-card:active { transform: scale(0.95); }

        /* DOWNLOADS */
        .profile-box { display: flex; align-items: center; padding: 80px 20px 20px; }
        .avatar { width: 60px; height: 60px; border-radius: 50%; background: #222; margin-right: 15px; border: 2px solid var(--accent); }
        .premium-card { background: #0f0f0f; margin: 0 15px; padding: 15px; border-radius: 12px; border: 1px solid #1a1a1a; }
        .dl-item { background: #080808; margin: 15px; padding: 15px; border-radius: 10px; border: 1px solid #1a1a1a; }
        .progress-bar { height: 4px; background: #222; width: 100%; margin: 10px 0; border-radius: 2px; }
        .progress-fill { height: 100%; background: var(--accent); width: 12%; box-shadow: 0 0 8px var(--accent); }
        .folder-grid { display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 10px; padding: 15px; }
        .folder-item { background: #111; padding: 15px; border-radius: 8px; text-align: center; font-size: 11px; border: 1px solid #222; cursor: pointer; }
        .folder-item:active { transform: scale(0.95); }

        /* ME PAGE */
        .me-header { padding: 80px 20px 10px; }
        .me-list { padding: 20px; line-height: 3; }
        .me-item { display: flex; align-items: center; justify-content: space-between; border-bottom: 1px solid #111; cursor: pointer; padding: 15px 0; }
        .switch { width: 40px; height: 20px; background: #333; border-radius: 10px; position: relative; cursor: pointer; transition: 0.3s; flex-shrink: 0; margin-left: 10px; }
        .switch.active { background: var(--accent); }
        .switch::after { content: ''; position: absolute; left: 2px; top: 2px; width: 16px; height: 16px; background: white; border-radius: 50%; transition: 0.3s; }
        .switch.active::after { left: 22px; }

        /* PLAYER */
        #player { position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: #000; z-index: 3000; display: none; flex-direction: column; }
        .video-area { flex: 1; display: flex; align-items: center; justify-content: center; position: relative; }
        .controls { padding: 25px; background: #0a0a0a; border-radius: 20px 20px 0 0; }

        /* NAVBAR */
        nav { position: fixed; bottom: 0; width: 100%; height: 75px; background: #000; border-top: 1px solid #222; display: flex; justify-content: space-around; align-items: center; z-index: 2000; }
        .nav-link { text-align: center; font-size: 10px; color: #555; cursor: pointer; }
        .nav-link.active { color: var(--accent); }
        .nav-link i { font-size: 22px; display: block; margin-bottom: 4px; }

        /* SUB PAGES - AGORA SÃO PÁGINAS INDEPENDENTES */
        .sub-page { display: none; animation: fadeIn 0.4s; min-height: 100vh; padding-bottom: 80px; }
        .sub-page.active { display: block; }
        .page-header { display: flex; align-items: center; padding: 60px 15px 15px; border-bottom: 1px solid #222; background: var(--bg); position: sticky; top: 0; z-index: 100; }
        .page-header i { margin-right: 15px; color: var(--accent); cursor: pointer; font-size: 20px; }
        .page-header h2 { margin: 0; font-size: 18px; }

        /* LIST STYLES */
        .content-list { padding: 15px; }
        .list-item { 
            display: flex; 
            align-items: center; 
            padding: 15px; 
            background: #111; 
            margin-bottom: 10px; 
            border-radius: 10px; 
            border: 1px solid #222;
            cursor: pointer;
            transition: 0.2s;
        }
        .list-item:active { background: #1a1a1a; }
        .list-thumb { 
            width: 80px; 
            height: 120px; 
            background: #222; 
            border-radius: 6px; 
            margin-right: 15px; 
            background-size: cover;
            background-position: center;
            flex-shrink: 0;
        }
        .list-info { flex: 1; }
        .list-title { font-size: 14px; margin-bottom: 5px; font-weight: bold; }
        .list-meta { font-size: 11px; color: var(--gray); }
        .list-action { color: var(--accent); font-size: 18px; padding: 10px; }

        /* COMMENTS */
        .comment-item { 
            background: #111; 
            padding: 15px; 
            border-radius: 10px; 
            margin-bottom: 10px; 
            border: 1px solid #222;
        }
        .comment-header { display: flex; justify-content: space-between; margin-bottom: 10px; align-items: center; }
        .comment-user { font-weight: bold; color: var(--accent); }
        .comment-date { font-size: 10px; color: var(--gray); }
        .comment-text { font-size: 13px; line-height: 1.5; color: #ccc; }
        .comment-movie { font-size: 11px; color: var(--accent); margin-top: 8px; }

        /* PREMIUM PAGE */
        .premium-hero { text-align: center; padding: 100px 20px 40px; background: linear-gradient(180deg, rgba(0,242,255,0.1) 0%, transparent 100%); }
        .premium-hero h1 { color: var(--accent); font-size: 32px; margin-bottom: 10px; }
        .premium-hero p { color: var(--gray); font-size: 14px; }
        .plan-card { 
            background: linear-gradient(135deg, #1a1a1a 0%, #0a0a0a 100%); 
            border: 1px solid var(--accent); 
            border-radius: 15px; 
            padding: 25px; 
            margin: 15px; 
            position: relative;
            overflow: hidden;
        }
        .plan-card.popular::before {
            content: 'POPULAR';
            position: absolute;
            top: 10px;
            right: -30px;
            background: var(--accent);
            color: #000;
            padding: 5px 40px;
            font-size: 10px;
            font-weight: bold;
            transform: rotate(45deg);
        }
        .plan-name { font-size: 20px; font-weight: bold; margin-bottom: 5px; }
        .plan-price { font-size: 32px; color: var(--accent); margin: 15px 0; }
        .plan-price span { font-size: 14px; color: var(--gray); }
        .plan-features { list-style: none; padding: 0; margin: 20px 0; }
        .plan-features li { padding: 8px 0; font-size: 13px; border-bottom: 1px solid #222; }
        .plan-features li i { color: var(--accent); margin-right: 10px; }
        .plan-btn { 
            width: 100%; 
            background: var(--accent); 
            border: none; 
            padding: 15px; 
            border-radius: 8px; 
            color: #000; 
            font-weight: bold; 
            font-size: 16px;
            cursor: pointer;
        }

        /* SEARCH - SÓ NA HOME */
        .search-overlay { 
            display: none; 
            position: fixed; 
            top: 0; 
            left: 0; 
            width: 100%; 
            height: 100%; 
            background: var(--bg); 
            z-index: 2500; 
            padding: 80px 15px 20px;
        }
        .search-overlay.active { display: block; }
        .search-header { display: flex; align-items: center; margin-bottom: 20px; position: fixed; top: 0; left: 0; right: 0; padding: 15px; background: var(--bg); z-index: 100; }
        .search-header input { 
            flex: 1; 
            background: rgba(255,255,255,0.1); 
            border: none; 
            padding: 12px 20px; 
            border-radius: 25px; 
            color: white;
            margin-right: 10px;
        }
        .no-results { text-align: center; padding: 60px 20px; color: var(--gray); }
        .no-results i { font-size: 48px; margin-bottom: 15px; opacity: 0.5; }

        /* FOLDER VIEWS */
        .folder-view { display: none; padding: 80px 15px 20px; }
        .folder-view.active { display: block; }
        .folder-header { display: flex; align-items: center; padding: 15px; border-bottom: 1px solid #222; margin-bottom: 20px; }
        .folder-header i { margin-right: 15px; color: var(--accent); cursor: pointer; }
        .file-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 15px; padding: 0 10px; }
        .file-item { background: #111; border-radius: 12px; overflow: hidden; border: 1px solid #222; position: relative; cursor: pointer; }
        .file-thumb { width: 100%; height: 120px; background: #222; display: flex; align-items: center; justify-content: center; font-size: 30px; color: var(--accent); }
        .file-thumb.video { background: linear-gradient(135deg, #1a1a1a 0%, #0a0a0a 100%); }
        .file-thumb.video::before { content: '\f04b'; font-family: 'Font Awesome 6 Free'; font-weight: 900; font-size: 40px; color: var(--accent); opacity: 0.8; }
        .file-info { padding: 10px; font-size: 11px; }
        .file-name { color: white; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; margin-bottom: 5px; }
        .file-meta { color: var(--gray); font-size: 10px; display: flex; justify-content: space-between; }
        .file-size { color: var(--accent); }
        .transfer-badge { position: absolute; top: 8px; right: 8px; background: var(--accent); color: #000; padding: 3px 8px; border-radius: 10px; font-size: 9px; font-weight: bold; }
        .transfer-badge.received { background: #00ff88; }
        .transfer-badge.sent { background: #ffaa00; }
        .local-file-list { padding: 0 15px; }
        .local-file-item { display: flex; align-items: center; padding: 15px; background: #111; margin-bottom: 10px; border-radius: 10px; border: 1px solid #222; cursor: pointer; }
        .local-file-icon { width: 50px; height: 50px; background: #222; border-radius: 10px; display: flex; align-items: center; justify-content: center; margin-right: 15px; font-size: 24px; color: var(--accent); }
        .local-file-info { flex: 1; }
        .local-file-name { font-size: 13px; margin-bottom: 5px; }
        .local-file-path { font-size: 10px; color: var(--gray); }
        #file-input { display: none; }

        @keyframes fadeIn { from { opacity: 0; } to { opacity: 1; } }
    </style>
</head>
<body>

<!-- HEADER - SÓ VISÍVEL NA HOME -->
<header id="main-header" class="active">
    <img src="https://i.ibb.co/XZpqHLfz/1000007315.jpg" class="logo-img">
    <div class="search-box">
        <input type="text" placeholder="Procurar filmes, séries..." id="searchInput" onkeyup="handleSearch(event)">
        <i class="fas fa-search" style="color:var(--accent)"></i>
    </div>
</header>

<!-- SEARCH OVERLAY - SÓ PARA CONTEÚDO DO APP -->
<div id="search-overlay" class="search-overlay">
    <div class="search-header">
        <input type="text" placeholder="Procurar..." id="searchInputOverlay" onkeyup="performSearch(this.value)">
        <i class="fas fa-times" style="color:var(--accent); font-size:20px; cursor:pointer;" onclick="closeSearch()"></i>
    </div>
    <div id="searchContent" style="margin-top: 80px;">
        <div class="no-results">
            <i class="fas fa-search"></i>
            <p>Digite para buscar filmes, séries, dorama...</p>
        </div>
    </div>
</div>

<!-- HOME PAGE -->
<div id="p-home" class="page active">
    <div class="hero" id="heroSlide" onclick="openPlayer('The Beekeeper')">
        <div class="info-box"><h2>The Beekeeper</h2><p>2025 Action ⬇️</p></div>
    </div>
    <div id="cat-list"></div>
</div>

<!-- DOWNLOADS PAGE -->
<div id="p-dl" class="page">
    <div id="dl-main-view">
        <div class="profile-box"><div class="avatar"></div><div><b>Soraia Manuel</b><br><small style="color:var(--accent)">Free Plan</small></div></div>
        <div class="premium-card">
            <small>Obtém os teus benefícios premium</small>
            <div style="font-size:10px; color:var(--gray)">(No ads 🍿) (720p Quality 💎) (Multi downloads 👑)</div>
            <div style="margin-top:10px"><b>Check-in diário</b></div>
            <div style="display:flex; gap:5px; margin:10px 0">
                <div style="background:#222; padding:5px 10px; border-radius:4px">⭐+2</div><div style="background:#222; padding:5px 10px; border-radius:4px">⭐+2</div>
            </div>
            <div style="display:flex; justify-content:space-between; align-items:center; background:#1a1a1a; padding:10px; border-radius:8px">
                <small>Watch 30min (5/30) ⭐+1</small><button style="background:var(--accent); border:none; padding:4px 10px; border-radius:4px; font-weight:bold">Watch</button>
            </div>
        </div>
        <div style="padding:20px 20px 0; display:flex; justify-content:space-between"><b>Downloads (2)</b><i class="fas fa-bars"></i></div>
        <div class="dl-item">
            <div style="display:flex; justify-content:space-between; font-size:12px"><span>Beekeeper 360p</span><span style="color:red">No internet</span></div>
            <div class="progress-bar"><div class="progress-fill"></div></div>
            <div style="display:flex; justify-content:space-between; font-size:10px; color:var(--gray)"><span>92.5MB / 858.3MB</span><span style="color:var(--accent)">Pause</span></div>
        </div>
        
        <div class="folder-grid">
            <div class="folder-item" onclick="openBRMFolder()">
                <i class="fas fa-folder" style="font-size:24px; color:var(--accent); margin-bottom:8px; display:block;"></i>
                1 BRM
                <div style="font-size:9px; color:var(--gray); margin-top:5px;" id="brm-count">3 itens</div>
            </div>
            <div class="folder-item" onclick="openLocalFolder()">
                <i class="fas fa-mobile-alt" style="font-size:24px; color:var(--accent); margin-bottom:8px; display:block;"></i>
                2 Local
                <div style="font-size:9px; color:var(--gray); margin-top:5px;">Explorar</div>
            </div>
            <div class="folder-item" onclick="openReceiveFolder()">
                <i class="fas fa-share-alt" style="font-size:24px; color:var(--accent); margin-bottom:8px; display:block;"></i>
                3 Receive
                <div style="font-size:9px; color:var(--gray); margin-top:5px;" id="receive-count">0 transferências</div>
            </div>
        </div>
    </div>

    <div id="brm-folder" class="folder-view">
        <div class="folder-header">
            <i class="fas fa-arrow-left" onclick="backToMain()"></i>
            <h3 style="margin:0;">Pasta BRM</h3>
        </div>
        <div class="file-grid" id="brm-content"></div>
    </div>

    <div id="local-folder" class="folder-view">
        <div class="folder-header">
            <i class="fas fa-arrow-left" onclick="backToMain()"></i>
            <h3 style="margin:0;">Arquivos Locais</h3>
        </div>
        <div style="padding:0 15px 15px;">
            <button onclick="selectLocalFiles()" style="width:100%; background:var(--accent); border:none; padding:12px; border-radius:8px; color:#000; font-weight:bold;">
                <i class="fas fa-folder-open"></i> Selecionar da Galeria
            </button>
        </div>
        <div class="local-file-list" id="local-content">
            <div style="text-align:center; padding:40px; color:var(--gray);">
                <i class="fas fa-folder-open" style="font-size:48px; margin-bottom:15px; opacity:0.3;"></i>
                <p>Nenhum arquivo selecionado</p>
                <p style="font-size:11px; margin-top:10px;">Clique acima para importar vídeos do seu dispositivo</p>
            </div>
        </div>
    </div>

    <div id="receive-folder" class="folder-view">
        <div class="folder-header">
            <i class="fas fa-arrow-left" onclick="backToMain()"></i>
            <h3 style="margin:0;">Transferências</h3>
        </div>
        <div style="padding:0 15px 15px; text-align:center; color:var(--gray); font-size:12px;">
            <i class="fas fa-info-circle"></i> Arquivos recebidos de outros apps aparecem aqui
        </div>
        <div class="file-grid" id="receive-content"></div>
    </div>
</div>

<!-- PREMIUM PAGE -->
<div id="p-premium" class="page">
    <div class="premium-hero">
        <h1><i class="fas fa-crown"></i> Premium</h1>
        <p>Desbloqueie todo o potencial do BRM Pro Max</p>
    </div>
    
    <div class="plan-card popular">
        <div class="plan-name">Plano Anual</div>
        <div style="font-size:12px; color:var(--gray);">Economize 40%</div>
        <div class="plan-price">R$ 99,90<span>/ano</span></div>
        <ul class="plan-features">
            <li><i class="fas fa-check"></i> Sem anúncios</li>
            <li><i class="fas fa-check"></i> Qualidade 4K</li>
            <li><i class="fas fa-check"></i> Downloads ilimitados</li>
            <li><i class="fas fa-check"></i> Streaming em 4 dispositivos</li>
            <li><i class="fas fa-check"></i> Conteúdo exclusivo</li>
        </ul>
        <button class="plan-btn" onclick="subscribe('annual')">Assinar Agora</button>
    </div>

    <div class="plan-card">
        <div class="plan-name">Plano Mensal</div>
        <div style="font-size:12px; color:var(--gray);">Flexibilidade total</div>
        <div class="plan-price">R$ 14,90<span>/mês</span></div>
        <ul class="plan-features">
            <li><i class="fas fa-check"></i> Sem anúncios</li>
            <li><i class="fas fa-check"></i> Qualidade 1080p</li>
            <li><i class="fas fa-check"></i> Downloads limitados</li>
            <li><i class="fas fa-check"></i> Streaming em 2 dispositivos</li>
        </ul>
        <button class="plan-btn" onclick="subscribe('monthly')" style="background:transparent; border:2px solid var(--accent); color:var(--accent);">Assinar Mensal</button>
    </div>
</div>

<!-- ME PAGE -->
<div id="p-me" class="page">
    <div class="me-header"><h2>Configurações</h2><small>ID: 526097803</small></div>
    <div class="me-list">
        <div class="me-item" onclick="toggleFamilyMode()">
            <span><i class="fas fa-users"></i> Modo Família</span>
            <div class="switch" id="familySwitch"></div>
        </div>
        <div class="me-item" onclick="openSubPage('mylist')">
            <span><i class="fas fa-bookmark"></i> Minha Lista 🔖</span>
            <i class="fas fa-chevron-right" style="color:var(--gray);"></i>
        </div>
        <div class="me-item" onclick="openSubPage('history')">
            <span><i class="fas fa-history"></i> Histórico 👀</span>
            <i class="fas fa-chevron-right" style="color:var(--gray);"></i>
        </div>
        <div class="me-item" onclick="openSubPage('liked')">
            <span><i class="fas fa-heart"></i> Meus Curtidos ❤️</span>
            <i class="fas fa-chevron-right" style="color:var(--gray);"></i>
        </div>
        <div class="me-item" onclick="openSubPage('comments')">
            <span><i class="fas fa-comment"></i> Comentários</span>
            <i class="fas fa-chevron-right" style="color:var(--gray);"></i>
        </div>
        <div style="color:var(--accent); font-weight:bold; margin-top:20px; cursor:pointer; padding: 15px 0;" onclick="window.open('https://brm.ph', '_blank')">
            <i class="fas fa-globe"></i> Official Web: BRM.Ph
        </div>
    </div>
</div>

<!-- SUB PAGES - AGORA FORA DAS PÁGINAS PRINCIPAIS -->
<div id="sub-mylist" class="sub-page">
    <div class="page-header">
        <i class="fas fa-arrow-left" onclick="closeSubPage()"></i>
        <h2>Minha Lista</h2>
    </div>
    <div class="content-list" id="mylist-content"></div>
</div>

<div id="sub-history" class="sub-page">
    <div class="page-header">
        <i class="fas fa-arrow-left" onclick="closeSubPage()"></i>
        <h2>Histórico</h2>
    </div>
    <div class="content-list" id="history-content"></div>
</div>

<div id="sub-liked" class="sub-page">
    <div class="page-header">
        <i class="fas fa-arrow-left" onclick="closeSubPage()"></i>
        <h2>Meus Curtidos</h2>
    </div>
    <div class="content-list" id="liked-content"></div>
</div>

<div id="sub-comments" class="sub-page">
    <div class="page-header">
        <i class="fas fa-arrow-left" onclick="closeSubPage()"></i>
        <h2>Meus Comentários</h2>
    </div>
    <div class="content-list" id="comments-content"></div>
</div>

<!-- PLAYER -->
<div id="player">
    <div style="padding:20px; display:flex; justify-content:space-between">
        <i class="fas fa-chevron-left" onclick="closePlayer()"></i><span id="p-title">Beekeeper</span><i class="fas fa-cog"></i>
    </div>
    <div class="video-area"><i class="fas fa-play-circle" style="font-size:60px; color:var(--accent)"></i></div>
    <div class="controls">
        <div class="progress-bar"><div class="progress-fill" style="width:40%"></div></div>
        <div style="display:flex; justify-content:space-around; margin:20px 0; font-size:20px">
            <i class="fas fa-backward"></i><i class="fas fa-pause"></i><i class="fas fa-forward"></i>
        </div>
        <div style="display:flex; justify-content:space-between; font-size:11px; color:var(--gray)">
            <span>Velocidade: 1.0x</span><span>Qualidade: 720p</span><span>Legenda: PT</span>
        </div>
    </div>
</div>

<input type="file" id="file-input" accept="video/*,audio/*,image/*" multiple onchange="handleLocalFiles(this.files)">

<nav>
