                    <div style="font-size:9px; color:var(--gray); margin-top:5px;">${file.date}</div>
                </div>
            </div>
        `).join('');
    }

    function updateReceiveCount() {
        document.getElementById('receive-count').textContent = receiveFiles.length + ' transferências';
    }

    function backToMain() {
        document.querySelectorAll('.folder-view').forEach(v => v.classList.remove('active'));
        document.getElementById('dl-main-view').style.display = 'block';
    }
