        document.querySelectorAll('.page').forEach(p => p.classList.remove('active'));
        document.querySelectorAll('.nav-link').forEach(n => n.classList.remove('active'));
        document.getElementById(id).classList.add('active');
        if (el) el.classList.add('active');
        const header = document.getElementById('main-header');
        id === 'p-home' ? header.classList.add('active') : header.classList.remove('active');
        window.scrollTo(0, 0);
    }

    // Slider Hero
    let cur = 0;
    function rotate() {
        const h = document.getElementById('heroSlide');
        if(!allMovies.length) return;
        const destaque = allMovies[cur % allMovies.length];
        h.style.backgroundImage = `url('${destaque.img}')`;
        h.innerHTML = `<div class="info-box"><h2>${destaque.title}</h2><p>Destaque de Hoje ⬇️</p></div>`;
        cur++;
    }
    setInterval(rotate, 5000);

    // ... (Mantenha o restante das suas funções de busca e pastas como estão)
</script>

